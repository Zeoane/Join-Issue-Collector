# Root environment template for Docker Compose and shared local setup.
# Copy to .env and fill in values. Service-specific templates:
#   backend/.env.example
#   frontend/.env.example

COMPOSE_PROJECT_NAME=join-issue-collector

# Shared secret: must match backend N8N_API_SECRET and n8n workflow credentials
N8N_API_SECRET=replace-with-strong-random-secret

FIREBASE_PROJECT_ID=join-issue-collector-70cb7

# Optional ports for compose.yaml
BACKEND_PORT=3001
FRONTEND_PORT=5173
