# Backend API – copy to backend/.env

PORT=3001
NODE_ENV=development

# Comma-separated origins allowed by CORS (local Vite default)
CORS_ORIGIN=http://localhost:5173

# Firebase Admin SDK
FIREBASE_PROJECT_ID=join-issue-collector-70cb7
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# Internal n8n webhook auth (header: X-N8N-Secret or Authorization: Bearer ...)
N8N_API_SECRET=replace-with-strong-random-secret
