# Backend API – copy to backend/.env

PORT=3001
NODE_ENV=development

# Firebase Admin SDK (Realtime Database)
FIREBASE_PROJECT_ID=join-issue-collector-70cb7
FIREBASE_DATABASE_URL=https://join-issue-collector-70cb7-default-rtdb.europe-west1.firebasedatabase.app
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# Board user that receives n8n-created tasks (Firebase Auth UID)
DEMO_USER_UID=replace-with-your-firebase-auth-uid

# Use quotes when the secret contains # (otherwise dotenv treats # as a comment).
N8N_API_SECRET="replace-with-strong-random-secret"
