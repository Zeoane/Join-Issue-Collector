{
  "database": {
    "rules": "database.rules.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".github/**",
      "backend/**",
      "functions/**",
      "frontend/**",
      "tests/**",
      "coverage/**"
    ],
    "rewrites": [
      {
        "source": "/internal/n8n/tasks",
        "function": "internalN8nTasks"
      }
    ]
  }
}
